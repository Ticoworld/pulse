# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_OWNER_CHAT_ID=your_telegram_chat_id_here

# API
PORT=3000

# Database (Supabase: use pooler URI from Project Settings → Database)
DATABASE_URL=your_supabase_pooler_url

# Supabase (Phase 10A+)
SUPABASE_URL=your_project_url
SUPABASE_ANON_KEY=your_anon_key
# Optional, for service-role access if needed:
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_optional

# Cache (optional; unused in current code)
REDIS_URL=redis://localhost:6379

# Helius (Solana RPC/streaming)
HELIUS_API_KEY=your_helius_api_key_here
HELIUS_NETWORK=mainnet
# Optional overrides:
# HELIUS_WS_URL=wss://mainnet.helius-rpc.com
# HELIUS_RPC_HTTP_URL=https://mainnet.helius-rpc.com
# STREAM_TARGET_PROGRAMS=9xQeWvG816bUx9EPjHmaT23yvVM2ZWbrrpZb9PusVFin,whirLbMiicVdio4qvUfM5KAg6Ct8VwpYzGff3uctyCc,JUP6LkbZbjS1jKKwapdHNy74zcZ3tLUZoi5QNyVTaV4
# Engine
ENGINE_REPLAY_FROM_START=false
ENGINE_IGNORED_MINTS=So11111111111111111111111111111111111111112,EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v,Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB

# Bags (read-only API; Phase 1)
BAGS_API_KEY=your_bags_api_key_here
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Executor Configurations (Phase 8+)
EXECUTOR_ENABLED=false
PAPER_TRADING=true
EXECUTOR_MIN_SCORE=70
EXECUTOR_BUY_AMOUNT_SOL=0.05
EXECUTOR_MAX_SLIPPAGE_BPS=1000
EXECUTOR_POLL_INTERVAL_MS=5000
